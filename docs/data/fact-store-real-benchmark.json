{
  "facts_count": 31,
  "queries_meta": [
    {
      "qid": "Q1",
      "query_natural": "我之前 sonnet 4.6 不是配过吗，是 1m 还是 200k？",
      "query_keywords": "sonnet 4.6 context",
      "intent": "查 Bedrock context 长度的具体数字",
      "expected_my_ids": [
        7,
        105
      ],
      "expected_actual_ids": [
        7,
        24
      ],
      "rationale": "fact 7 明确说 Sonnet 4.6 是 200K（不要记错成 1M）；memory 105 也提到 Opus 1M / Sonnet 200K context 数字别记错"
    },
    {
      "qid": "Q2",
      "query_natural": "我有哪些飞书相关的 cron",
      "query_keywords": "飞书 cron",
      "intent": "查所有飞书 + cron 关联的项目",
      "expected_my_ids": [
        6,
        201
      ],
      "expected_actual_ids": [
        6,
        26
      ],
      "rationale": "fact 6 是 NewsBot（前缀 newsbot 飞书 cron 每日简报 ec71837e0a3e），201 是北京时区/cron 时差换算的硬约束"
    },
    {
      "qid": "Q3",
      "query_natural": "agent-reach 装在哪？",
      "query_keywords": "agent-reach 安装路径",
      "intent": "查具体安装位置",
      "expected_my_ids": [
        1,
        101
      ],
      "expected_actual_ids": [
        1,
        20
      ],
      "rationale": "fact 1 明确说 ~/.local/bin/（pipx），memory 101 说 web 搜索栈搭好包含 agent-reach"
    },
    {
